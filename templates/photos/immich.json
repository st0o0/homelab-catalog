{
  "type": 3,
  "title": "Immich",
  "description": "Self-hosted photo management with server, ML, database, and cache",
  "logo": "https://raw.githubusercontent.com/immich-app/immich/main/docs/static/img/favicon.png",
  "categories": ["Photos"],
  "repository": {
    "url": "https://github.com/st0o0/homelab-catalog",
    "stackfile": "stacks/immich/compose.yml"
  },
  "env": [
    { "name": "DB_PASSWORD", "label": "Database Password", "default": "" },
    { "name": "DB_USERNAME", "label": "Database User", "default": "postgres" },
    { "name": "DB_DATABASE_NAME", "label": "Database Name", "default": "immich" },
    { "name": "UPLOAD_PATH", "label": "Upload Path on Host", "default": "/data/immich/upload" },
    { "name": "IMMICH_PORT", "label": "Exposed Port", "default": "2283" },
    { "name": "TZ", "label": "Timezone", "default": "Europe/Berlin" }
  ],
  "note": "Deploys 4 containers: immich-server, immich-ml, postgres (pgvecto-rs), redis"
}
