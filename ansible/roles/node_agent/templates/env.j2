# Managed by Ansible -- do not edit manually.
HOST_HOSTNAME={{ node_agent_hostname }}
TZ={{ node_agent_tz }}
{% if node_agent_alloy_enabled %}

# Alloy
SCRAPE_INTERVAL={{ node_agent_scrape_interval }}
REMOTE_WRITE_URL=http://{{ node_agent_obs_host }}:8428/api/v1/write
LOGS_PUSH_URL=http://{{ node_agent_obs_host }}:9428/insert/loki/api/v1/push
{% endif %}
{% if node_agent_hawser_enabled %}

# Dockhand
DOCKHAND_SERVER_URL={{ node_agent_dockhand_url }}
DOCKHAND_TOKEN={{ node_agent_dockhand_token }}
AGENT_NAME={{ node_agent_hostname }}
HEARTBEAT_INTERVAL={{ node_agent_dockhand_heartbeat }}
{% endif %}
{% if node_agent_bifrost_enabled %}

# Bifrost
BIFROST_PRIVATE_KEY={{ node_agent_bifrost_private_key }}
BIFROST_ADDRESS={{ node_agent_bifrost_address }}
BIFROST_LISTEN_PORT={{ node_agent_bifrost_listen_port }}
BIFROST_MTU={{ node_agent_bifrost_mtu }}
BIFROST_PEER_PUBLIC_KEY={{ node_agent_bifrost_peer_public_key }}
BIFROST_PEER_ENDPOINT={{ node_agent_bifrost_peer_endpoint }}
BIFROST_PEER_ALLOWED_IPS={{ node_agent_bifrost_peer_allowed_ips }}
BIFROST_PEER_KEEPALIVE={{ node_agent_bifrost_peer_keepalive }}
BIFROST_PEER_PRESHARED_KEY={{ node_agent_bifrost_peer_preshared_key }}
{% endif %}
