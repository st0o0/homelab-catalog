{% raw %}#!/bin/bash
# Managed by Ansible -- do not edit manually.

# Colors (avoid hardcoded white/black — they invert badly on light-background
# terminals; bold/dim adapt to whatever fg the terminal theme defines)
R='\e[0m'
G='\e[1;32m'
C='\e[1;36m'
Y='\e[1;33m'
RED='\e[1;31m'
W='\e[1m'
D='\e[2m'

# System info
HOSTNAME=$(hostname)
KERNEL=$(uname -r)
OS=$(. /etc/os-release 2>/dev/null && echo "$PRETTY_NAME" || uname -o)
PKGS=$(dpkg -l 2>/dev/null | grep -c '^ii' || echo "?")
IP_ALL=$(hostname -I | xargs | sed 's/ /, /g')
UPTIME=$(uptime -p | sed 's/up //')

# Performance
LOAD_PCT=$(awk '{printf "%.0f", $1 * 100 / '"$(nproc)"'}' /proc/loadavg)
MEM_PCT=$(free | awk '/^Mem:/{printf "%.0f", $3/$2*100}')
MEM_TOTAL=$(free -h | awk '/^Mem:/{print $2}')
DISK_PCT=$(df / | awk 'NR==2{gsub(/%/,""); print $5}')
DISK_USED=$(df -h / | awk 'NR==2{print $3}')
DISK_TOTAL=$(df -h / | awk 'NR==2{print $2}')

# CPU
CPU_MODEL=$(awk -F: '/model name/{print $2; exit}' /proc/cpuinfo | sed 's/^ *//')
[ -z "$CPU_MODEL" ] && CPU_MODEL=$(awk -F: '/^model|Hardware/{print $2; exit}' /proc/cpuinfo | sed 's/^ *//')
CPU_CORES=$(nproc)
CPU_TEMP=""
if [ -f /sys/class/thermal/thermal_zone0/temp ]; then
    RAW=$(cat /sys/class/thermal/thermal_zone0/temp)
    CPU_TEMP="$((RAW / 1000))°C"
fi
CPU_LINE="${CPU_MODEL:-unknown} (${CPU_CORES} cores)"
[ -n "$CPU_TEMP" ] && CPU_LINE="${CPU_LINE}, ${CPU_TEMP}"

# Docker containers
DOCKER_LINE=""
if command -v docker &>/dev/null; then
    NAMES=$(docker ps --format '{{.Names}}' 2>/dev/null | sort | paste -sd', ' -)
    COUNT=$(docker ps -q 2>/dev/null | wc -l)
    [ "$COUNT" -gt 0 ] && DOCKER_LINE=" ${W}Containers:${R}   ${NAMES}"
fi

# Config tool (OS-specific, first match wins)
CONFIG_CMD=""
command -v armbian-config &>/dev/null && CONFIG_CMD="armbian-config"
[ -z "$CONFIG_CMD" ] && command -v raspi-config &>/dev/null && CONFIG_CMD="raspi-config"
[ -z "$CONFIG_CMD" ] && command -v nmtui &>/dev/null && CONFIG_CMD="nmtui"

# Monitoring tool (first available wins)
MONITOR_CMD=""
command -v btop &>/dev/null && MONITOR_CMD="btop"
[ -z "$MONITOR_CMD" ] && command -v htop &>/dev/null && MONITOR_CMD="htop"
[ -z "$MONITOR_CMD" ] && command -v top &>/dev/null && MONITOR_CMD="top"

# Color for percentage
cpc() {
    [ "$1" -ge 85 ] && echo -ne "${RED}" && return
    [ "$1" -ge 60 ] && echo -ne "${Y}" && return
    echo -ne "${G}"
}

# Two-column row: label1 value1 label2 value2 (col1 fixed at 34 visible chars)
row2() {
    local l1="$1" v1="$2" l2="$3" v2="$4"
    local col1
    col1=$(printf "  %b%-14s%b%b" "$W" "$l1" "$R" "$v1")
    # pad col1 to a fixed visible width (34 chars) ignoring ANSI escapes
    local visible
    visible=$(echo -e "$col1" | sed 's/\x1b\[[0-9;]*m//g')
    local pad=$((34 - ${#visible}))
    [ "$pad" -lt 1 ] && pad=1
    printf "%b" "$col1"
    printf "%${pad}s" ""
    [ -n "$l2" ] && printf "%b%-9s%b%b\n" "$W" "$l2" "$R" "$v2" || printf "\n"
}

# Header
BANNER=$(figlet -f small "$HOSTNAME" 2>/dev/null || echo " $HOSTNAME")
echo ""
echo -e "${C}${BANNER}${R}"
echo -e " ${G}${OS}${R}"
echo ""
echo -e " ${W}Kernel:${R}       ${KERNEL}"
echo -e " ${W}Packages:${R}     ${PKGS}"
echo -e " ${W}IPv4:${R}         ${IP_ALL}"
[ -n "$DOCKER_LINE" ] && echo -e "$DOCKER_LINE"

# Performance
echo ""
echo -e " ${C}Performance:${R}"
echo ""
row2 "Uptime:" "${UPTIME}" "" ""
row2 "CPU:" "${CPU_LINE}" "" ""
row2 "Load:" "$(cpc $LOAD_PCT)${LOAD_PCT}%${R}" "Memory:" "$(cpc $MEM_PCT)${MEM_PCT}%${R} of ${MEM_TOTAL}"
row2 "Disk /:" "$(cpc $DISK_PCT)${DISK_PCT}%${R} of ${DISK_TOTAL}" "Usage:" "${DISK_USED} / ${DISK_TOTAL}"

# Storage (real mounts, one per line)
declare -a ST_N=() ST_P=() ST_U=() ST_T=()
while IFS= read -r line; do
    m=$(echo "$line" | awk '{print $6}')
    p=$(echo "$line" | awk '{gsub(/%/,""); print $5}')
    u=$(echo "$line" | awk '{print $3}')
    t=$(echo "$line" | awk '{print $2}')
    n=$(basename "$m")
    [ "$n" = "/" ] && n="root"
    ST_N+=("$n"); ST_P+=("$p"); ST_U+=("$u"); ST_T+=("$t")
done < <(df -h --output=source,size,used,avail,pcent,target 2>/dev/null \
    | awk 'NR>1 && $1 !~ /^(tmpfs|overlay|devtmpfs|udev|shm|none)/' \
    | grep -v '/boot\|/snap\|/run\|/sys\|/proc\|/dev\|/etc/pve\|subvol-')

ST_COUNT=${#ST_N[@]}
if [ "$ST_COUNT" -gt 1 ]; then
    echo ""
    echo -e " ${C}Storage:${R}"
    echo ""
    for ((i=0; i<ST_COUNT; i++)); do
        # Pad name to 14 chars
        PADDED=$(printf "%-14s" "${ST_N[$i]}")
        echo -e "  ${D}${PADDED}${R}  $(cpc ${ST_P[$i]})${ST_P[$i]}%${R}\tof ${ST_T[$i]}\t(${ST_U[$i]} used)"
    done
fi

echo ""
if [ -n "$CONFIG_CMD" ] || [ -n "$MONITOR_CMD" ]; then
    echo -e " ${C}Commands:${R}"
    echo ""
    [ -n "$CONFIG_CMD" ] && echo -e "  Configuration: ${G}${CONFIG_CMD}${R}"
    [ -n "$MONITOR_CMD" ] && echo -e "  Monitoring:    ${G}${MONITOR_CMD}${R}"
    echo ""
fi

# Last login
LAST=$(last -1 -R "$USER" 2>/dev/null | head -1)
if [ -n "$LAST" ] && ! echo "$LAST" | grep -q "^$"; then
    LOGIN_TIME=$(echo "$LAST" | awk '{for(i=3;i<=NF;i++) printf "%s ", $i}' | xargs)
    echo -e " ${D}Last login: ${LOGIN_TIME}${R}"
    echo ""
fi
{% endraw %}
